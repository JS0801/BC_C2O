<#-- ==================== TIME TYPE LEGEND ==================== -->
<#assign TIME_LEGEND_MAP = {"ST": "Standard Time", "OT": "Overtime", "DT": "Double Time", "PT": "Premium Time", "PTO": "Paid Time Off", "Per Diem": "Per Diem Allowance", "DR1": "Day Rate 1", "DR2": "Day Rate 2", "DR3": "Day Rate 3", "DR1-OT": "Day Rate 1 Overtime", "DR2-OT": "Day Rate 2 Overtime"} />
<#assign LEGEND_ORDER = ["ST", "OT", "DT", "PT", "PTO", "Per Diem", "DR1", "DR2", "DR3", "DR1-OT", "DR2-OT"] />
<#assign seenTypes = {} />
<#assign legendEntries = [] />
<#list x.Labor as labor>
  <#if labor.employee != 'TOTAL' && labor?index != 0>
    <#assign st = labor.shiftType?trim />
    <#if st?has_content && !seenTypes[st]??>
      <#assign seenTypes = seenTypes + {st: true} />
    </#if>
  </#if>
</#list>
<#list LEGEND_ORDER as key>
  <#if seenTypes[key]??>
    <#assign legendEntries = legendEntries + [{"abbr": key, "label": TIME_LEGEND_MAP[key]!key}] />
  </#if>
</#list>
<#if legendEntries?has_content>
<table style="width: 100%; font-size: 6pt; margin-top: 10px; border-top: 1px solid #000; page-break-inside: avoid;">
  <tr>
    <td style="padding-top: 5px; padding-bottom: 4px; font-size: 6pt;">
      <strong>Time Type Legend:</strong>
      <#list legendEntries as leg>
        &nbsp;&nbsp;<strong>${leg.abbr}</strong> &#8211; ${leg.label}<#if leg?has_next> &nbsp;|</#if>
      </#list>
    </td>
  </tr>
</table>
</#if>
<#-- ==================== END LEGEND ==================== -->

